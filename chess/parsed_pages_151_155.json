        "interactive_section": {
          "starting_move": 6,
          "moves": [
            {
              "move_number": 6,
              "player": "W",
              "move": "Bg5",
              "commentary": "In this section White delays the development of his king's knight as he usually prefers a set-up with Bd3 and Nge2."
            },
            {
              "move_number": 6,
              "player": "B",
              "move": "Na6",
              "commentary": "Black prepares the traditional King's Indian central strike ...e7-e5."
            },
            {
              "move_number": 7,
              "player": "W",
              "move": "Bd3",
              "commentary": ""
